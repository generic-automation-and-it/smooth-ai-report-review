{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "gemini": {
      "npm": "@ai-sdk/google",
      "name": "Gemini",
      "options": {
        "apiKey": "{env:OPENCODE_GEMINI_API_KEY}"
      },
      "models": {
        "gemini-3.1-pro-preview":  { "name": "Gemini 3.1 Pro (preview)" },
        "gemini-2.5-pro":          { "name": "Gemini 2.5 Pro" },
        "gemini-3-flash-preview":  { "name": "Gemini 3 Flash (preview)" },
        "gemini-2.5-flash":        { "name": "Gemini 2.5 Flash" }
      }
    },
    "github-copilot": {
      "npm": "@ai-sdk/github-copilot",
      "name": "GitHub Copilot",
      "options": {
        "apiKey": "{env:OPENCODE_COPILOT_API_KEY}"
      },
      "models": {
        "gpt-5.5": { "name": "GPT-5.5" },
        "gpt-5.4": { "name": "GPT-5.4" },
        "gpt-5.4-mini": { "name": "GPT-5.4 mini" }
      }
    },
    "openai": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI",
      "options": {
        "apiKey": "{env:OPENCODE_OPENAI_API_KEY}"
      },
      "models": {
        "gpt-5.5": { "name": "GPT-5.5" },
        "gpt-5.4": { "name": "GPT-5.4" },
        "gpt-5.4-mini": { "name": "GPT-5.4 mini" }
      }
    },
    "go-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go (OpenAI-compatible)",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:OPENCODE_GO_OPENAI_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": { "name": "DeepSeek V4 Flash" },
        "deepseek-v4-pro":   { "name": "DeepSeek V4 Pro" },
        "glm-5.1":           { "name": "GLM-5.1" }
      }
    },
    "go-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "OpenCode Go (Anthropic-compatible)",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:OPENCODE_GO_ANTHROPIC_API_KEY}"
      },
      "models": {
        "minimax-m3":   { "name": "MiniMax M3" },
        "minimax-m2.7": { "name": "MiniMax M2.7" },
        "qwen3.7-plus": { "name": "Qwen3.7 Plus" },
        "qwen3.6-pro":  { "name": "Qwen3.6 Pro" }
      }
    }
  },
  "permission": {
    "external_directory": "allow"
  },
  "agent": {
    "review": {
      "mode": "primary",
      "description": "Locked-down PR-review agent (LADR-029): no skill/task/edit/write/bash; read + web (fetch/search) enabled. Disabling skill/task stops the review model self-activating this repo's own ai-review-report skill when a chunk under review contains the gate's workflow/skill files (the empty-output / silent-failure mode); bash is denied so a prompt-injected diff cannot run arbitrary commands on the runner, while webfetch/websearch stay on so the model can verify references during review.",
      "tools": {
        "skill": false,
        "task": false,
        "edit": false,
        "write": false,
        "bash": false,
        "webfetch": true,
        "websearch": true
      },
      "permission": {
        "skill": "deny",
        "task": "deny",
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "external_directory": "allow"
      }
    }
  }
}
