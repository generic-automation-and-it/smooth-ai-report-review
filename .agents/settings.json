{
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "compileCommands": [
    "dotnet build"
  ],
  "testCommands": [
    "dotnet test"
  ],
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(docker-compose:*)",
      "Bash(dotnet ef migrations add:*)",
      "Bash(dotnet tool install:*)",
      "Bash(dotnet tool restore:*)",
      "Bash(env)",
      "Bash(gh api:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr reviews:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run view:*)",
      "Bash(az:*)",
      "Bash(git grep:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git pull:*)",
      "Bash(git reset:*)",
      "Skill(ai-review)",
      "Skill(ai-review-report)",
      "Skill(git-commit-review-push)",
      "Bash(node:*)",
      "Bash(powershell.exe:*)",
      "Bash(python3:*)",
      "Bash(ren:*)",
      "Bash(rmdir:*)",
      "Bash(sqlcmd:*)",
      "Bash(where:*)",
      "Bash(yamllint:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.conventionalcommits.org)"
    ],
    "deny": [
      "Bash(gh pr merge*--delete-branch*)",
      "Bash(gh pr merge*-d*)",
      "Bash(gh api*DELETE*refs/heads*)",
      "Bash(gh api*DELETE*git/refs*)",
      "Bash(dotnet ef database update:*)",
      "Bash(sqlcmd*INSERT*)",
      "Bash(sqlcmd*insert*)",
      "Bash(sqlcmd*UPDATE*)",
      "Bash(sqlcmd*update*)",
      "Bash(sqlcmd*DELETE*)",
      "Bash(sqlcmd*delete*)",
      "Bash(sqlcmd*DROP*)",
      "Bash(sqlcmd*drop*)",
      "Bash(sqlcmd*TRUNCATE*)",
      "Bash(sqlcmd*truncate*)"
    ],
    "ask": [
      "Bash(gh pr close:*)"
    ]
  }
}
